# 复制此文件为 api-data.env 并填入你的 API 密钥
# Copy this file to api-data.env and fill in your API keys

# 百度 OCR（可选 / optional）
# BAIDU_API_KEY=your_baidu_api_key
# BAIDU_SECRET_KEY=your_baidu_secret_key

# DeepSeek AI 评分（可选 / optional）
# DEEPSEEK_API_KEY=your_deepseek_api_key
# GRADER_MODEL=deepseek-chat

# AIGC检测 ZeroTrue（可选 / optional）
# ZEROTRUE_API_KEY=your_zerotrue_api_key

# OCR 配置（可选 / optional）
# HC_RE_AI_OCR_LANG_LIST=ch_sim,en
# HC_RE_AI_OCR_GPU=false
# HC_RE_AI_OCR_MODEL_STORAGE_DIR=
# HC_RE_AI_OCR_DOWNLOAD_ENABLED=true

# HTTP 服务配置（可选 / optional）
# HC_RE_AI_HTTP_HOST=0.0.0.0
# HC_RE_AI_HTTP_PORT=8000
